# auth - JWT
# JWT 서명에 사용할 비밀키 (임의의 긴 문자열)
JWT_SECRET=your_super_secret_jwt_key_here

# auth - spotify
# 스포티파이 토큰 발급 URL (고정값)
SPOTIFY_TOKEN_URL=https://accounts.spotify.com/api/token
# 스포티파이 개발자 대시보드에서 발급받은 Client ID
SPOTIFY_CLIENT_ID=your_spotify_client_id
# 스포티파이 로그인 후 리다이렉트될 URI (프론트엔드 주소)
SPOTIFY_REDIRECT_URI=http://localhost:3000/auth/spotify/callback

# api - spotify
# 스포티파이 API 기본 주소 (고정값)
SPOTIFY_API_BASE_URL=https://api.spotify.com/v1

# db - dev
# 로컬 개발 환경용 MySQL 설정
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=1234
DB_DATABASE=vibr

# Neo4j 
# 로컬 개발 환경용 Neo4j 설정
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=12345678

# redis
# 로컬 개발 환경용 Redis 설정
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=1234

# Google OAuth 2.0
# 구글 클라우드 콘솔에서 발급받은 Client ID
GOOGLE_CLIENT_ID=your_google_client_id
# 구글 클라우드 콘솔에서 발급받은 Client Secret
GOOGLE_CLIENT_SECRET=your_google_client_secret
# 구글 로그인 후 리다이렉트될 URI (프론트엔드 주소)
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# Server Configuration
PORT=3002
NODE_ENV=development

# AWS S3 (게시글 커버이미지 저장)
# 버킷 리전 (예: ap-northeast-2 서울)
AWS_REGION=ap-northeast-2
# 사용할 S3 버킷 이름 (퍼블릭 read를 위해 버킷 정책 필요)
AWS_S3_BUCKET_NAME=your_bucket_name
# 자격증명: 로컬 개발용 IAM 사용자 키.
# EC2(프로덕션)는 인스턴스 IAM 롤을 쓰므로 아래 두 값은 넣지 않는다.
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key